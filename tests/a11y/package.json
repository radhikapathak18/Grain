{
  "name": "@grain/tests-a11y",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "description": "Accessibility test suite for Grain. Component-level scans via vitest + axe-core; page-level scaffold via Playwright + @axe-core/playwright.",
  "scripts": {
    "test": "vitest run --config ./vitest.config.ts",
    "test:watch": "vitest --config ./vitest.config.ts",
    "test:pw": "playwright test --config ./playwright.config.ts",
    "install:browsers": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.49.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.5.2",
    "@vitejs/plugin-react": "^6.0.1",
    "axe-core": "^4.10.2",
    "jsdom": "^25.0.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.1.0",
    "vitest": "^2.1.9",
    "vitest-axe": "^0.1.0",
    "@tanstack/react-query": "^5.62.0",
    "@grain/types": "workspace:*",
    "lucide-react": "^0.475.0",
    "zustand": "^5.0.2"
  }
}
