{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "types": ["node"],
    "noEmit": true,
    "allowImportingTsExtensions": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "resolveJsonModule": true
  },
  "include": [
    "./harness/**/*.ts",
    "./dataset/**/*.ts",
    "./judges/**/*.ts",
    "./shims/**/*.ts",
    "./scripts/**/*.ts"
  ]
}
